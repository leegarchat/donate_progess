<?xml version="1.0" encoding="utf-8"?>
<!--
    iOS-style close enter: the previous activity slides back from
    its -30 % parallax position and brightens to full opacity.
    Reverse of ios_open_exit.
-->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:interpolator="@android:interpolator/linear_out_slow_in">
    <translate
        android:fromXDelta="-30%p"
        android:toXDelta="0"
        android:duration="350" />
    <alpha
        android:fromAlpha="0.65"
        android:toAlpha="1.0"
        android:duration="350" />
</set>
