<?xml version="1.0" encoding="utf-8"?>
<!-- iOS close-enter for direction=bottom: previous returns from UP −30 %. -->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:interpolator="@android:interpolator/linear_out_slow_in">
    <translate android:fromYDelta="-30%p" android:toYDelta="0" android:duration="350" />
    <alpha android:fromAlpha="0.65" android:toAlpha="1.0" android:duration="350" />
</set>
